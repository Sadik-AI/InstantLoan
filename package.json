{
  "name": "ws-computer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx watch backend/src/server.ts",
    "dev:full": "concurrently -k \"npm run server\" \"npm run dev\"",
    "build:frontend": "vite build",
    "build:server": "tsc -p backend/tsconfig.json",
    "build": "npm run build:frontend && npm run build:server",
    "preview": "vite preview",
    "start": "node backend/dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p backend/tsconfig.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.546.0",
    "mongoose": "^8.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
